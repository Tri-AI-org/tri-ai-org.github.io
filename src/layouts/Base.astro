---
import '../styles/global.css';
import Header from '../components/Header.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noFooter?: boolean;
}

const {
  title = 'TRI AI — Teaching, Research, Innovation in AI for Africa',
  description = 'TRI AI is the institutional home for programmes, research initiatives, and collaborations advancing AI knowledge across the African continent and the global research community.',
  ogImage = '/og-default.png',
  noFooter = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme bootstrap (prevent flash) -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('triai-theme');
          if (t === 'light' || t === 'dark') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <Header />
    <AnnouncementBar />
    <main id="main">
      <slot />
    </main>
    {!noFooter && <Footer />}

    <!-- Netlify Identity (for Decap CMS auth) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" defer></script>

    <!-- Scroll-reveal: adds .in-view to [data-reveal] / [data-reveal-stagger] when they enter the viewport -->
    <script is:inline>
      (function () {
        if (typeof window === 'undefined') return;
        var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var targets = document.querySelectorAll('[data-reveal], [data-reveal-stagger]');
        if (!targets.length) return;
        if (prefersReduced || !('IntersectionObserver' in window)) {
          targets.forEach(function (el) { el.classList.add('in-view'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.12 });
        targets.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
