---
import { getCollection } from 'astro:content';

const allPubs = await getCollection('publications', ({ data }) => !data.draft);
const allNews = await getCollection('news', ({ data }) => !data.draft);

// Combine into unified "feed" sorted by date
type Item = {
  href: string;
  title: string;
  date: Date;
  division: string;
  kind: string;
  cover?: string;
};

const items: Item[] = [
  ...allPubs.map(p => ({
    href: `/publications/${p.id}`,
    title: p.data.title,
    date: p.data.date,
    division: p.data.division,
    kind: 'Publication',
  })),
  ...allNews.map(n => ({
    href: `/news/${n.id}`,
    title: n.data.title,
    date: n.data.date,
    division: n.data.division,
    kind: 'News',
    cover: n.data.cover,
  })),
];

items.sort((a, b) => b.date.getTime() - a.date.getTime());
const recent = items.slice(0, 6);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

{recent.length > 0 && (
  <div class="feed">
    {recent.map((it, i) => (
      <a href={it.href} class={`feed-item feed-item-${it.division}`} style={`--i:${i}`}>
        <p class="feed-meta">
          <span class="feed-date mono">{fmt(it.date)}</span>
          <span class={`feed-tag tag tag-${it.division}`}>
            {it.division}
          </span>
        </p>
        <h3 class="feed-title">{it.title}</h3>
        <p class="feed-kind">{it.kind} <span class="arrow" aria-hidden="true">→</span></p>
      </a>
    ))}
  </div>
)}

{recent.length === 0 && (
  <p class="feed-empty">Publications and news will appear here as they are published.</p>
)}

<style>
  .feed {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .feed-item {
    background: var(--bg-elev);
    padding: 28px 26px 24px;
    display: flex;
    flex-direction: column;
    min-height: 220px;
    transition: background 0.25s var(--ease-quick);
  }
  .feed-item:hover { background: var(--bg-soft); }

  .feed-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .feed-date {
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.2em;
  }
  .feed-tag {
    font-size: 9px;
    padding: 3px 8px;
  }

  .feed-title {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--ink);
    flex: 1;
    margin-bottom: 18px;
  }
  .feed-kind {
    font-size: 13px;
    color: var(--ink-mid);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .feed-kind .arrow { transition: transform 0.2s var(--ease-quick); }
  .feed-item:hover .feed-kind .arrow { transform: translateX(4px); }
  .feed-item:hover .feed-kind { color: var(--ink); }

  .feed-empty {
    padding: 32px;
    text-align: center;
    color: var(--ink-faint);
    border: 1px dashed var(--line);
    border-radius: 10px;
  }

  @media (max-width: 820px) {
    .feed { grid-template-columns: 1fr; }
  }
</style>
