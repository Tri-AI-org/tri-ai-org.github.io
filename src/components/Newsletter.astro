---
/**
 * Newsletter — "The Encoder"
 *
 * Compact single-strip layout. Posts to the AI Saturdays Lagos
 * subscribers API. Handles success / already-subscribed / error states
 * inline (no separate confirmation page needed).
 *
 * The API expects:
 *   POST https://ai6lagos.bestregards.me/api/v1/subscribers
 *   { email, firstName, lastName, sources: [{ type, id }] }
 *
 * Returns 200 with { status: 'UNCONFIRMED', ... } on success (double opt-in
 * means the user still has to click a confirmation link in their email).
 */
---

<section class="nl" id="newsletter" aria-labelledby="nl-h">
  <div class="container nl-inner">
    <div class="nl-head">
      <p class="mono nl-eyebrow">Newsletter</p>
      <h2 id="nl-h" class="nl-title">
        <span class="nl-name">The Encoder<span class="nl-name-dot">.</span></span>
      </h2>
      <p class="nl-desc">
        Monthly updates from The Encoder &mdash; programmes, research, opportunities. - a TRI AI Initiative
      </p>
    </div>

    <form class="nl-form" id="nl-form" novalidate>
      <div class="nl-row">
        <label class="nl-field nl-field-half">
          <span class="nl-label">First name</span>
          <input
            type="text"
            name="firstName"
            autocomplete="given-name"
            placeholder="First"
          />
        </label>
        <label class="nl-field nl-field-half">
          <span class="nl-label">Last name</span>
          <input
            type="text"
            name="lastName"
            autocomplete="family-name"
            placeholder="Last"
          />
        </label>
      </div>
      <label class="nl-field nl-field-email">
        <span class="nl-label">Email</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
        />
      </label>
      <button type="submit" class="btn btn-primary nl-submit">
        <span class="nl-submit-label">Subscribe</span>
      </button>

      <p class="nl-status" data-nl-status role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var form = document.getElementById('nl-form');
    if (!form) return;
    var status = form.querySelector('[data-nl-status]');
    var submitBtn = form.querySelector('.nl-submit');
    var submitLabel = form.querySelector('.nl-submit-label');

    function setStatus(message, kind) {
      if (!status) return;
      status.textContent = message;
      status.className = 'nl-status nl-status-' + (kind || 'info');
    }

    function setLoading(loading) {
      if (loading) {
        submitBtn.setAttribute('disabled', 'true');
        if (submitLabel) submitLabel.textContent = 'Subscribing...';
      } else {
        submitBtn.removeAttribute('disabled');
        if (submitLabel) submitLabel.textContent = 'Subscribe';
      }
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var formData = new FormData(form);
      var email = (formData.get('email') || '').toString().trim();
      var firstName = (formData.get('firstName') || '').toString().trim();
      var lastName = (formData.get('lastName') || '').toString().trim();

      if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
        setStatus('Please enter a valid email.', 'error');
        return;
      }

      var payload = {
        email: email,
        firstName: firstName,
        lastName: lastName,
      };

      setLoading(true);
      setStatus('', 'info');

      fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then(function (res) {
          return res.json().then(function (data) {
            return { ok: res.ok, status: res.status, data: data };
          });
        })
        .then(function (result) {
          setLoading(false);
          if (result.ok && (result.data.status === 'UNCONFIRMED' || result.data.type === 'success')) {
            setStatus("Almost there. Check your inbox to confirm your subscription.", 'success');
            form.reset();
          } else if (result.status === 409 || (result.data && /already|exist/i.test(result.data.message || ''))) {
            setStatus("You're already subscribed. Check your inbox for past issues.", 'info');
          } else {
            setStatus(
              (result.data && result.data.message) ||
                'Something went wrong. Please try again in a moment.',
              'error'
            );
          }
        })
        .catch(function () {
          setLoading(false);
          setStatus('Network error. Please check your connection and try again.', 'error');
        });
    });
  })();
</script>

<style>
  .nl {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--bg-soft);
    padding-block: clamp(36px, 4.5vw, 56px);
  }
  .nl-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: clamp(32px, 4vw, 56px);
    align-items: center;
  }

  /* ─── Brand block: "The Encoder" ─── */
  .nl-eyebrow {
    color: var(--ink-faint);
    margin-bottom: 10px;
  }
  .nl-title {
    margin: 0 0 8px;
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .nl-name {
    color: var(--ink);
    font-style: italic;
  }
  .nl-name-dot {
    color: var(--gold);
    font-style: normal;
    margin-left: 1px;
  }
  .nl-desc {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-mid);
    max-width: 38ch;
    margin: 0;
  }

  /* ─── Form ─── */
  .nl-form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px;
    align-items: end;
  }
  .nl-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    grid-column: 1 / -1;
  }
  .nl-field { min-width: 0; }
  .nl-field-email { grid-column: 1; }
  .nl-submit { grid-column: 2; }

  .nl-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--t-mono-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 6px;
  }
  .nl-form input[type='email'],
  .nl-form input[type='text'] {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    font-size: 14.5px;
    font-family: var(--font-sans);
    transition: border-color 0.2s var(--ease-quick), box-shadow 0.2s var(--ease-quick);
  }
  .nl-form input:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(212, 160, 23, 0.15);
  }
  .nl-submit {
    padding: 12px 22px;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .nl-submit[disabled] {
    opacity: 0.55;
    cursor: progress;
  }

  /* ─── Inline status (success / error / info) ─── */
  .nl-status {
    grid-column: 1 / -1;
    margin: 4px 0 0;
    font-size: 13px;
    line-height: 1.5;
    min-height: 1.2em;
    transition: color 0.2s;
  }
  .nl-status:empty { display: none; }
  .nl-status-success { color: var(--success, #2E8B57); }
  .nl-status-error { color: var(--alert, #D94141); }
  .nl-status-info { color: var(--ink-mid); }
  [data-theme='dark'] .nl-status-success { color: #5BBA85; }
  [data-theme='dark'] .nl-status-error { color: #FF7777; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .nl-status-success { color: #5BBA85; }
    :root:not([data-theme]) .nl-status-error { color: #FF7777; }
  }

  @media (max-width: 820px) {
    .nl-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .nl-form {
      grid-template-columns: 1fr;
    }
    .nl-submit {
      grid-column: 1;
      justify-self: start;
    }
  }

  @media (max-width: 480px) {
    .nl-row {
      grid-template-columns: 1fr;
    }
  }
</style>
