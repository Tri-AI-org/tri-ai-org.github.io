---
// Posts directly to the bestregards.me subscribers API
const API_URL = "https://ai6lagos.bestregards.me/api/v1/subscribers";
const FORM_ID = "form_wv8XxtbD7WDIWY7AaxV-b";
---

<section class="nl" id="newsletter" aria-labelledby="nl-h">
  <div class="container nl-inner">
    <div class="nl-head">
      <p class="mono">Stay connected</p>
      <h2 id="nl-h" class="nl-title">TRI AI Dispatch</h2>
      <p class="nl-desc">
        Monthly updates on programmes, research, and opportunities - delivered straight to your inbox.
      </p>
    </div>
    <form
      class="nl-form"
      id="nl-form"
      novalidate
      data-api={API_URL}
      data-form-id={FORM_ID}
    >
      <label class="nl-field">
        <span class="nl-label">First name</span>
        <input
          type="text"
          name="firstName"
          required
          placeholder="Ada"
          autocomplete="given-name"
        />
      </label>
      <label class="nl-field">
        <span class="nl-label">Last name</span>
        <input
          type="text"
          name="lastName"
          required
          placeholder="Lovelace"
          autocomplete="family-name"
        />
      </label>
      <label class="nl-field nl-field-full">
        <span class="nl-label">Email</span>
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
        />
      </label>
      <button type="submit" class="btn btn-primary nl-submit">Subscribe</button>
      <p class="nl-msg" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  .nl {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--bg-soft);
    padding-block: 80px;
  }
  .nl-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .nl-head .mono { margin-bottom: 12px; }
  .nl-title {
    font-size: var(--t-h1);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--ink);
  }
  .nl-desc {
    margin-top: 12px;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--ink-mid);
    max-width: 44ch;
  }

  .nl-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .nl-field-full,
  .nl-submit,
  .nl-msg { grid-column: 1 / -1; }
  .nl-submit { justify-self: start; padding: 14px 24px; }

  .nl-label {
    display: block;
    font-size: var(--t-mono);
    font-family: var(--font-mono);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }
  .nl-form input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    font-size: 14px;
    transition: border-color 0.2s var(--ease-quick);
  }
  .nl-form input:focus {
    outline: none;
    border-color: var(--gold);
  }
  .nl-submit[disabled] { opacity: 0.6; cursor: not-allowed; }

  .nl-msg {
    margin: 4px 0 0;
    font-size: 13px;
    line-height: 1.5;
    min-height: 1.5em;
    color: var(--ink-mid);
  }
  .nl-msg[data-state='ok']  { color: var(--gold); }
  .nl-msg[data-state='err'] { color: #c0392b; }

  @media (max-width: 820px) {
    .nl-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .nl-form { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement | null;
  if (form) {
    const submit = form.querySelector('.nl-submit') as HTMLButtonElement;
    const msg    = form.querySelector('.nl-msg') as HTMLElement;
    const fields = {
      firstName: form.querySelector('input[name="firstName"]') as HTMLInputElement,
      lastName:  form.querySelector('input[name="lastName"]')  as HTMLInputElement,
      email:     form.querySelector('input[name="email"]')     as HTMLInputElement,
    };

    const setMsg = (text: string, state: '' | 'ok' | 'err' = '') => {
      msg.textContent = text;
      if (state) msg.dataset.state = state;
      else delete msg.dataset.state;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const firstName = fields.firstName.value.trim();
      const lastName  = fields.lastName.value.trim();
      const email     = fields.email.value.trim();

      if (!firstName || !lastName || !email || !fields.email.checkValidity()) {
        setMsg('Please fill in your name and a valid email.', 'err');
        return;
      }

      const api    = form.dataset.api!;
      const formId = form.dataset.formId!;

      setMsg('', '');
      submit.disabled = true;
      const originalLabel = submit.textContent;
      submit.textContent = 'Subscribing…';

      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            firstName,
            lastName,
            sources: [{ type: 'FORM', id: formId }],
          }),
        });

        const data = await res.json().catch(() => ({} as any));

        if (!res.ok || data.type !== 'success') {
          throw new Error(data.message || 'Something went wrong. Please try again.');
        }

        setMsg('Almost there — check your inbox to confirm your subscription.', 'ok');
        form.reset();
        submit.textContent = 'Subscribed';
      } catch (err) {
        setMsg(err instanceof Error ? err.message : 'Something went wrong.', 'err');
        submit.disabled = false;
        submit.textContent = originalLabel;
      }
    });
  }
</script>