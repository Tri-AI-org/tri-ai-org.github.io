---
/**
 * CohortMarquee - a horizontal strip showing every cohort number,
 * pinned to the bottom of the homepage Teaching panel or the
 * Saturdays detail page. Hover-pause; clicking jumps to archive.
 *
 * The point: prove there's a real history without taking up a section.
 */
import { getCollection } from 'astro:content';

const cohorts = (await getCollection('cohorts'))
  .filter(c => c.data.programme === 'tri-ai-saturdays')
  .sort((a, b) => a.data.number - b.data.number);

const totalCount = cohorts.length;
---

{cohorts.length > 0 && (
  <section class="marquee" aria-label={`${totalCount} cohorts run since ${cohorts[0]?.data.year}`}>
    <div class="container">
      <div class="marquee-head">
        <span class="marquee-label mono">
          <span class="marquee-num">{totalCount}</span> cohorts of TRI AI Saturdays
        </span>
        <a href="/programmes/tri-ai-saturdays/cohorts" class="marquee-cta mono">
          See archive <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="marquee-track-wrap">
        <ul class="marquee-track">
          {cohorts.map(c => (
            <li class={`marquee-item ${c.data.status === 'upcoming' ? 'is-current' : ''} ${c.data.status === 'running' ? 'is-running' : ''}`}>
              <a href={`/programmes/tri-ai-saturdays/cohorts/${c.data.number}`} class="marquee-link">
                <span class="marquee-c mono">C{String(c.data.number).padStart(2, '0')}</span>
                <span class="marquee-y mono">{c.data.year}</span>
                {c.data.status === 'upcoming' && <span class="marquee-dot" aria-hidden="true"></span>}
                {c.data.status === 'running' && <span class="marquee-dot marquee-dot-active" aria-hidden="true"></span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>
)}

<style>
  .marquee {
    padding-block: 36px 32px;
    border-bottom: 1px solid var(--line);
    background: var(--bg-soft);
  }
  .marquee-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }
  .marquee-label {
    font-size: var(--t-mono);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }
  .marquee-num {
    color: var(--teaching);
    font-weight: 700;
    margin-right: 8px;
    font-size: 13px;
  }
  .marquee-cta {
    font-size: var(--t-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 3px;
    transition: border-color 0.2s, color 0.2s;
  }
  .marquee-cta:hover {
    border-color: var(--teaching);
    color: var(--teaching);
  }

  .marquee-track-wrap {
    overflow-x: auto;
    overflow-y: hidden;
    /* Smooth scroll, hide native scrollbar */
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .marquee-track-wrap::-webkit-scrollbar { height: 6px; }
  .marquee-track-wrap::-webkit-scrollbar-track { background: transparent; }
  .marquee-track-wrap::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 3px;
  }

  .marquee-track {
    display: flex;
    gap: 12px;
    list-style: none;
    padding: 4px 0;
    margin: 0;
  }
  .marquee-item { flex-shrink: 0; }
  .marquee-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px 10px 14px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg-elev);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s var(--ease-quick), background 0.2s;
  }
  .marquee-link:hover {
    border-color: var(--teaching);
    transform: translateY(-2px);
    background: var(--bg);
  }

  .marquee-c {
    font-size: 12px;
    letter-spacing: 0.14em;
    font-weight: 700;
    color: var(--ink);
  }
  .marquee-y {
    font-size: var(--t-mono-sm);
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }

  .marquee-item.is-current .marquee-link {
    border-color: var(--teaching);
    background: var(--teaching-light);
  }
  [data-theme='dark'] .marquee-item.is-current .marquee-link {
    background: rgba(254, 102, 18, 0.12);
  }
  .marquee-item.is-current .marquee-c { color: var(--teaching); }

  .marquee-item.is-running .marquee-link { border-color: var(--teaching); }
  .marquee-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }
  .marquee-dot-active {
    background: var(--teaching);
    animation: marquee-pulse 1.6s ease-in-out infinite;
  }
  @keyframes marquee-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.6; }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-dot-active { animation: none; }
  }
</style>
