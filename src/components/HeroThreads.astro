---
/**
 * HeroThreads - three thin curves (orange/blue/teal) that draw in on page load
 * and converge toward the right edge. The TRI AI brand signature, in motion.
 *
 * Sits absolutely behind/around the headline, decorative only.
 */
---

<svg
  class="threads"
  viewBox="0 0 600 400"
  preserveAspectRatio="xMinYMax meet"
  aria-hidden="true"
  focusable="false"
>
  <!-- Three threads weave horizontally and converge near the right -->
  <path class="thread t-teaching"
        d="M 0 80 C 180 80, 220 200, 380 200 S 560 200, 600 200"
        fill="none" stroke-width="1.25" stroke-linecap="round" />
  <path class="thread t-research"
        d="M 0 200 C 180 200, 220 200, 380 200 S 560 200, 600 200"
        fill="none" stroke-width="1.25" stroke-linecap="round" />
  <path class="thread t-innovation"
        d="M 0 320 C 180 320, 220 200, 380 200 S 560 200, 600 200"
        fill="none" stroke-width="1.25" stroke-linecap="round" />

  <!-- Convergence dot at end -->
  <circle class="thread-dot" cx="598" cy="200" r="3" />
</svg>

<style>
  .threads {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 50%;
    height: 60%;
    pointer-events: none;
    opacity: 0.25;
  }
  [data-theme='dark'] .threads { opacity: 0.4; }

  .thread {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    animation: thread-draw 1.6s var(--ease) forwards;
  }
  .t-teaching { stroke: var(--teaching); animation-delay: 0.15s; }
  .t-research { stroke: var(--research-text); animation-delay: 0.30s; }
  .t-innovation { stroke: var(--innovation); animation-delay: 0.45s; }

  .thread-dot {
    fill: var(--gold);
    opacity: 0;
    animation: thread-dot 0.5s var(--ease) forwards 1.6s;
  }

  @keyframes thread-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes thread-dot {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .thread { stroke-dashoffset: 0; animation: none; }
    .thread-dot { opacity: 1; animation: none; }
  }
</style>
