---
/**
 * DivisionPanel — a full-width section that gives one division
 * its own architectural space on the homepage. Used three times
 * (Teaching, Research, Innovation), each tinted with its colour.
 *
 * Pulls live items from the relevant collection(s) so editors can
 * shape what shows up by editing programmes/publications in the CMS.
 */
import { getCollection } from 'astro:content';

interface Item {
  href: string;
  title: string;
  meta: string;       // e.g. "Cohort programme · Lagos" or "Feb 2026 · Paper"
}

interface Props {
  number: string;             // "01" / "02" / "03"
  division: 'teaching' | 'research' | 'innovation';
  title: string;
  titleAccent?: string;       // optional second line — italic, division-coloured, smaller
  statement: string;          // one-sentence positioning statement
  ctaLabel: string;
  ctaHref: string;
  // Optional override — if not passed, the panel auto-pulls items from collections
  items?: Item[];
  emptyState?: string;        // shown when no items resolved (e.g. Innovation "in development")
  featuredImage?: string;     // optional hero image at top of right column
  featuredImageAlt?: string;
  featuredCaption?: string;   // small caption below the image
  featuredHref?: string;      // optional link wrapping the featured image
}

const { number, division, title, titleAccent, statement, ctaLabel, ctaHref, items: itemsProp, emptyState, featuredImage, featuredImageAlt, featuredCaption, featuredHref } = Astro.props;

let items: Item[] = itemsProp ?? [];

// Auto-resolve items if none provided
if (!itemsProp) {
  if (division === 'teaching') {
    const progs = (await getCollection('programmes'))
      .filter(p => p.data.division === 'teaching' && p.data.status === 'active')
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 4);
    items = progs.map(p => {
      const kindLabel: Record<string, string> = {
        cohort: 'Cohort programme',
        course: 'Course',
        'watch-party': 'Watch parties',
        colloquium: 'Colloquium',
      };
      const k = kindLabel[p.data.kind] || 'Programme';
      return {
        href: `/programmes/${p.id}`,
        title: p.data.title,
        meta: p.data.location ? `${k} · ${p.data.location}` : k,
      };
    });
  } else if (division === 'research') {
    const inits = (await getCollection('programmes'))
      .filter(p => p.data.division === 'research' && p.data.status === 'active')
      .sort((a, b) => a.data.order - b.data.order)
      .slice(0, 2);
    const pubs = (await getCollection('publications', ({ data }) => !data.draft))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      .slice(0, 2);
    items = [
      ...inits.map(p => ({
        href: `/programmes/${p.id}`,
        title: p.data.title,
        meta: 'Research initiative',
      })),
      ...pubs.map(p => ({
        href: `/research/publications/${p.id}`,
        title: p.data.title,
        meta: `${p.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} · ${p.data.venue || 'Publication'}`,
      })),
    ];
  }
  // innovation: no auto-fetch — uses emptyState
}
---

<section class={`dp dp-${division}`}>
  <div class="container">
    <div class="dp-grid">
      <header class="dp-head" data-reveal>
        <span class={`dp-num mono dp-num-${division}`}>{number}</span>
        <p class={`mono dp-eyebrow dp-eyebrow-${division}`}>TRI AI {division.charAt(0).toUpperCase() + division.slice(1)}</p>
        <h2 class="dp-title">
          {title}
          {titleAccent && (
            <><br/><span class={`dp-em dp-em-${division}`}>{titleAccent}</span></>
          )}
        </h2>
        <p class="dp-statement">{statement}</p>
        <a href={ctaHref} class="dp-cta">
          {ctaLabel} <span aria-hidden="true">→</span>
        </a>
      </header>

      <div class="dp-body">
        {featuredImage && (
          featuredHref ? (
            <a href={featuredHref} class="dp-feat" data-reveal>
              <img src={featuredImage} alt={featuredImageAlt || ''} class="dp-feat-img" loading="lazy" />
              {featuredCaption && <p class="dp-feat-cap mono">{featuredCaption}</p>}
            </a>
          ) : (
            <div class="dp-feat" data-reveal>
              <img src={featuredImage} alt={featuredImageAlt || ''} class="dp-feat-img" loading="lazy" />
              {featuredCaption && <p class="dp-feat-cap mono">{featuredCaption}</p>}
            </div>
          )
        )}

        {items.length > 0 ? (
          <ul class="dp-list" data-reveal-stagger>
            {items.map(it => (
              <li class="dp-item">
                <a href={it.href} class="dp-link">
                  <span class={`dp-marker dp-marker-${division}`} aria-hidden="true"></span>
                  <div class="dp-content">
                    <p class="dp-meta mono">{it.meta}</p>
                    <p class="dp-item-title">{it.title}</p>
                  </div>
                  <span class="dp-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        ) : !featuredImage ? (
          <div class="dp-empty" data-reveal>
            <p class="dp-empty-text">{emptyState}</p>
          </div>
        ) : null}

        {!items.length && featuredImage && emptyState && (
          <div class="dp-empty dp-empty-after" data-reveal>
            <p class="dp-empty-text">{emptyState}</p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .dp {
    padding-block: clamp(72px, 9vw, 120px);
    border-bottom: 1px solid var(--line);
  }
  .dp-teaching { background: var(--bg); }
  .dp-research { background: var(--bg-soft); }
  .dp-innovation { background: var(--bg); }

  .dp-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }

  .dp-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .dp-num {
    font-size: var(--t-mono);
    letter-spacing: 0.22em;
    margin-bottom: 28px;
  }
  .dp-num-teaching { color: var(--teaching); }
  .dp-num-research { color: var(--research-text); }
  .dp-num-innovation { color: var(--innovation); }

  .dp-eyebrow {
    font-size: var(--t-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .dp-eyebrow-teaching { color: var(--teaching); }
  .dp-eyebrow-research { color: var(--research-text); }
  .dp-eyebrow-innovation { color: var(--innovation); }

  .dp-title {
    font-size: var(--t-display-m);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 18px;
    max-width: 18ch;
  }
  .dp-em {
    display: inline-block;
    font-style: italic;
    font-weight: 600;
    /* One tier smaller than the primary title line */
    font-size: 0.78em;
    line-height: 1.15;
    margin-top: 4px;
  }
  .dp-em-teaching { color: var(--teaching); }
  .dp-em-research { color: var(--research-text); }
  .dp-em-innovation { color: var(--innovation); }
  .dp-statement {
    font-size: clamp(15.5px, 1.3vw, 17px);
    line-height: 1.6;
    color: var(--ink-mid);
    margin-bottom: 28px;
    max-width: 38ch;
  }
  .dp-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--t-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--ink);
    transition: gap 0.2s var(--ease-quick), border-color 0.2s;
  }
  .dp-cta:hover { gap: 12px; }
  .dp-teaching .dp-cta:hover { border-color: var(--teaching); }
  .dp-research .dp-cta:hover { border-color: var(--research-text); }
  .dp-innovation .dp-cta:hover { border-color: var(--innovation); }

  .dp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--line);
  }

  .dp-feat {
    display: block;
    margin-bottom: 28px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border-radius: 12px;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    position: relative;
    transition: transform 0.3s var(--ease-quick), border-color 0.3s var(--ease-quick), box-shadow 0.3s var(--ease-quick);
  }
  a.dp-feat:hover {
    transform: translateY(-3px);
    border-color: var(--line-strong);
    box-shadow: 0 12px 36px -16px rgba(20, 20, 20, 0.12);
  }
  [data-theme='dark'] a.dp-feat:hover {
    box-shadow: 0 12px 36px -16px rgba(0, 0, 0, 0.7);
  }
  .dp-feat-img {
    display: block;
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  a.dp-feat:hover .dp-feat-img {
    transform: scale(1.02);
  }
  .dp-feat-cap {
    padding: 14px 18px 16px;
    font-size: var(--t-mono-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mid);
    border-top: 1px solid var(--line);
  }
  .dp-empty-after { margin-top: 8px; }
  .dp-item { border-bottom: 1px solid var(--line); }
  .dp-link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 20px;
    align-items: center;
    padding: 22px 0 22px 4px;
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.25s var(--ease-quick);
  }
  .dp-link:hover { padding-left: 16px; }

  .dp-marker {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dp-marker-teaching { background: var(--teaching); }
  .dp-marker-research { background: var(--research-text); }
  .dp-marker-innovation { background: var(--innovation); }

  .dp-content { min-width: 0; }
  .dp-meta {
    font-size: var(--t-mono-sm);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 4px;
  }
  .dp-item-title {
    font-size: clamp(16px, 1.4vw, 19px);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
    transition: color 0.2s;
  }
  .dp-link:hover .dp-item-title { color: var(--gold-deep); }
  [data-theme='dark'] .dp-link:hover .dp-item-title { color: var(--gold); }

  .dp-arrow {
    color: var(--ink-faint);
    font-size: 20px;
    transition: transform 0.2s var(--ease-quick), color 0.2s;
  }
  .dp-link:hover .dp-arrow {
    transform: translateX(4px);
    color: var(--gold-deep);
  }

  .dp-empty {
    border: 1px dashed var(--line-strong);
    border-radius: 10px;
    padding: 32px 28px;
  }
  .dp-empty-text {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-mid);
    max-width: 50ch;
  }

  @media (max-width: 880px) {
    .dp-grid { grid-template-columns: 1fr; gap: 40px; }
    .dp-title { max-width: none; }
    .dp-statement { max-width: 60ch; }
  }
</style>
