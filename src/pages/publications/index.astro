---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const pubs = (await getCollection('publications', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Base title="Publications — TRI AI" description="Research publications from TRI AI's research initiatives.">
  <section class="hero-pub">
    <div class="container">
      <p class="mono">Publications</p>
      <h1 class="display hero-pub-h">
        Research, written<br/>
        from Africa.
      </h1>
      <p class="lede">
        Peer-reviewed papers, technical reports, and dataset releases from TRI AI's research initiatives.
      </p>
    </div>
  </section>

  <hr class="divider-rule" />

  <section class="section">
    <div class="container">
      {pubs.length > 0 ? (
        <ul class="pub-list">
          {pubs.map(p => (
            <li class="pub-item">
              <a href={`/publications/${p.id}`} class="pub-link">
                <div class="pub-meta">
                  <span class="pub-date mono">{fmt(p.data.date)}</span>
                  <span class={`tag tag-${p.data.division}`}>{p.data.division}</span>
                  {p.data.venue && <span class="pub-venue">{p.data.venue}</span>}
                </div>
                <h2 class="pub-title">{p.data.title}</h2>
                <p class="pub-authors">
                  {p.data.authors.slice(0, 5).join(', ')}
                  {p.data.authors.length > 5 && <span class="pub-etal"> et al.</span>}
                </p>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">Publications will appear here as they are released. Add them via /admin.</p>
      )}
    </div>
  </section>

  <Newsletter />
</Base>

<style>
  .hero-pub { padding-block: clamp(64px, 8vw, 112px); }
  .hero-pub .mono { margin-bottom: 16px; }
  .hero-pub-h {
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 24px;
    color: var(--ink);
  }

  .pub-list {
    list-style: none;
    border-top: 1px solid var(--line);
  }
  .pub-item {
    border-bottom: 1px solid var(--line);
  }
  .pub-link {
    display: block;
    padding: 32px 0;
    transition: background 0.2s var(--ease-quick);
    margin-inline: -16px;
    padding-inline: 16px;
    border-radius: 6px;
  }
  .pub-link:hover { background: var(--bg-soft); }

  .pub-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .pub-date { color: var(--ink-faint); font-size: 10px; }
  .pub-venue {
    font-size: 12px;
    color: var(--ink-mid);
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pub-title {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 10px;
    max-width: 64ch;
  }
  .pub-link:hover .pub-title { color: var(--gold-deep); }
  [data-theme='dark'] .pub-link:hover .pub-title { color: var(--gold); }

  .pub-authors {
    font-size: 14.5px;
    color: var(--ink-mid);
    line-height: 1.6;
  }
  .pub-etal { font-style: italic; color: var(--ink-faint); }

  .empty {
    padding: 40px;
    text-align: center;
    color: var(--ink-faint);
    border: 1px dashed var(--line);
    border-radius: 10px;
  }
</style>
