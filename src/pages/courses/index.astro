---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Courses — TRI AI">
  <section class="hero-cs">
    <div class="container">
      <p class="mono" style="color: var(--teaching)">Courses & Collaborations</p>
      <h1 class="display hero-cs-h">
        Learn AI,<br/>
        properly.
      </h1>
      <p class="lede">
        Foundational and advanced AI courses delivered with local mentorship, peer learning, and community support — in collaboration with global partners.
      </p>
    </div>
  </section>

  <hr class="divider-rule" />

  <section class="section">
    <div class="container">
      {courses.length > 0 ? (
        <div class="cs-grid">
          {courses.map(c => (
            <a href={`/courses/${c.id}`} class="cs-card">
              {c.data.cover && <div class="cs-cover" style={`background-image:url(${c.data.cover})`}></div>}
              <div class="cs-body">
                <div class="cs-meta">
                  <span class="tag tag-teaching">{c.data.track}</span>
                  {c.data.partner && <span class="cs-partner">w/ {c.data.partner}</span>}
                </div>
                <h2 class="cs-title">{c.data.title}</h2>
                <p class="cs-summary">{c.data.summary}</p>
                <span class="cs-link">View course →</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty">Courses will appear here. Add them via /admin.</p>
      )}
    </div>
  </section>

  <Newsletter />
</Base>

<style>
  .hero-cs { padding-block: clamp(64px, 8vw, 112px); }
  .hero-cs .mono { margin-bottom: 16px; }
  .hero-cs-h {
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 24px;
    color: var(--ink);
  }

  .cs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .cs-card {
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-elev);
    transition: border-color 0.25s, transform 0.25s;
    display: flex;
    flex-direction: column;
  }
  .cs-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .cs-cover {
    aspect-ratio: 16/10;
    background-size: cover;
    background-position: center;
    background-color: var(--bg-soft);
  }
  .cs-body { padding: 22px 22px 24px; }
  .cs-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .cs-partner {
    font-size: 11px;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .cs-title {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .cs-summary {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-mid);
    margin-bottom: 16px;
  }
  .cs-link {
    font-size: 11px;
    font-family: var(--font-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .empty {
    padding: 40px;
    text-align: center;
    color: var(--ink-faint);
    border: 1px dashed var(--line);
    border-radius: 10px;
  }

  @media (max-width: 920px) {
    .cs-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .cs-grid { grid-template-columns: 1fr; }
  }
</style>
