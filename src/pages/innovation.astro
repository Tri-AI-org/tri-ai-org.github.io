---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Newsletter from '../components/Newsletter.astro';

const focusAreas = [
  {
    title: 'Speech and language tooling',
    body: 'Translating Sauti Project research into production-ready tools — speech recognition for African languages packaged for use in apps, accessibility tooling, and field research.',
  },
  {
    title: 'Vision systems for African contexts',
    body: 'Building on ChowNet, applied vision systems for domains where mainstream models fail — food, agriculture, marketplace inventory, healthcare imaging.',
  },
  {
    title: 'Education infrastructure',
    body: 'Internal tooling that scales TRI AI Saturdays, watch parties, and the colloquium series — and which we plan to release publicly so other African AI communities can run their own programmes.',
  },
];
---

<Base
  title="Innovation — TRI AI"
  description="TRI AI Innovation translates teaching and research output into products and tools that serve African contexts directly."
>
  <section class="hero-i">
    <div class="container">
      <div class="accent-bar accent-innovation"></div>
      <p class="mono" style="color: var(--innovation)">TRI AI Innovation</p>
      <h1 class="display hero-i-h">
        Turning research
        <span class="hero-i-em">into things that ship.</span>
      </h1>
      <p class="lede">
        TRI AI Innovation is the youngest of our three divisions. Its job is to take the work emerging from Teaching and Research and translate it into products, tools, and spinouts that serve African contexts directly.
      </p>
      <p class="hero-i-status mono">
        <span class="hero-i-status-dot" aria-hidden="true"></span>
        Currently in development · First launches: late 2026
      </p>
    </div>
  </section>

  <hr class="divider-rule" />

  <section class="section">
    <div class="container">
      <div data-reveal>
        <SectionHeader num="01" eyebrow="Status" title="In development." />
      </div>
      <div class="i-status" data-reveal>
        <p class="i-status-body">
          We're prototyping our first launches across three areas — speech and language tooling, computer vision applied to African contexts, and education infrastructure. The first product release is targeted for late 2026; until then, this page is the public side of work that's happening internally.
        </p>
        <p class="i-status-body">
          If you're a researcher, engineer, or organisation interested in collaborating on an Innovation initiative — or you'd like to hear when the first products launch — get in touch.
        </p>
        <div class="i-status-actions">
          <a href="mailto:innovation@tri-ai.org" class="btn btn-primary btn-arrow">Contact Innovation</a>
          <a href="#newsletter" class="btn btn-ghost btn-arrow">Get launch updates</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider-rule" />

  <section class="section">
    <div class="container">
      <div data-reveal>
        <SectionHeader
          num="02"
          eyebrow="Focus areas"
          title="What we're building."
          description="Three areas where TRI AI's research and teaching naturally extend into shippable work."
        />
      </div>
      <div class="i-grid" data-reveal-stagger>
        {focusAreas.map((f, i) => (
          <article class="i-card">
            <span class="i-num mono">0{i + 1}</span>
            <h3 class="i-card-h">{f.title}</h3>
            <p class="i-card-body">{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Newsletter />
</Base>

<style>
  .hero-i { padding-block: clamp(64px, 8vw, 112px); }
  .hero-i .accent-bar { margin-bottom: 16px; }
  .hero-i .mono { margin-bottom: 16px; }
  .hero-i-h {
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 24px;
    color: var(--ink);
  }
  .hero-i-em {
    display: inline-block;
    color: var(--innovation);
    font-style: italic;
    font-weight: 600;
    font-size: 0.78em;
    line-height: 1.15;
    margin-top: 4px;
  }

  .hero-i-status {
    margin-top: 28px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }
  .hero-i-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--innovation);
    animation: hero-i-pulse 2s ease-in-out infinite;
  }
  @keyframes hero-i-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-i-status-dot { animation: none; }
  }

  .i-status {
    border: 1px solid var(--line);
    border-left: 3px solid var(--innovation);
    border-radius: 10px;
    padding: 36px 40px 40px;
    background: var(--bg-elev);
    max-width: 720px;
  }
  .i-status-body {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-mid);
    margin-bottom: 16px;
  }
  .i-status-body:last-of-type { margin-bottom: 0; }
  .i-status-actions {
    margin-top: 28px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .i-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 8px;
  }
  .i-card {
    border: 1px solid var(--line);
    border-top: 3px solid var(--innovation);
    border-radius: 0 0 10px 10px;
    padding: 28px 26px 30px;
    background: var(--bg-elev);
    transition: transform 0.25s var(--ease-quick), border-color 0.25s var(--ease-quick);
  }
  .i-card:hover {
    transform: translateY(-3px);
    border-color: var(--line-strong);
    border-top-color: var(--innovation);
  }
  .i-num {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--innovation);
    margin-bottom: 18px;
    display: block;
  }
  .i-card-h {
    font-size: 19px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .i-card-body {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-mid);
  }

  @media (max-width: 880px) {
    .i-grid { grid-template-columns: 1fr; }
  }
</style>
