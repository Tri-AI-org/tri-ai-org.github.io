---
import Base from '../layouts/Base.astro';
import Pillars from '../components/Pillars.astro';
import FeaturedFeed from '../components/FeaturedFeed.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Newsletter from '../components/Newsletter.astro';
import NowPanel from '../components/NowPanel.astro';
import HeroThreads from '../components/HeroThreads.astro';
import { getCollection } from 'astro:content';

const programmes = (await getCollection('programmes'))
  .filter(p => p.data.status === 'active')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const stats = [
  { num: '1,500+', label: 'Learners and community members' },
  { num: '8', label: 'Cohorts completed' },
  { num: '2', label: 'Active research initiatives' },
  { num: '5+', label: 'Years building AI communities' },
];
---

<Base
  title="TRI AI — Teaching, Research, Innovation in AI for Africa"
  description="TRI AI is a non-governmental institution building African communities for learning, research, and the development of AI solutions — published in the open."
>
  <!-- Hero — split-grid: headline + live Now panel -->
  <section class="hero">
    <HeroThreads />
    <div class="container hero-grid">
      <div class="hero-main">
        <p class="hero-eyebrow mono reveal reveal-1">
          Teaching <span class="he-sep">·</span>
          Research <span class="he-sep">·</span>
          Innovation
        </p>

        <h1 class="hero-h reveal reveal-2">
          AI for Africa,<br/>
          <span class="hero-h-accent">built in the open.</span>
        </h1>

        <p class="hero-lede reveal reveal-3">
          TRI AI is a non-governmental institution democratising artificial intelligence — building African communities for learning, research, and the development of AI solutions for local and global impact.
        </p>

        <div class="hero-actions reveal reveal-4">
          <a href="/programmes" class="btn btn-primary btn-arrow">Explore programmes</a>
          <a href="/research" class="btn btn-ghost btn-arrow">Our research</a>
        </div>
      </div>

      <div class="hero-now reveal reveal-5">
        <NowPanel />
      </div>
    </div>

    <!-- Division stripe — architectural footer to the hero -->
    <div class="hero-stripe" aria-hidden="true">
      <span class="hs hs-t"></span>
      <span class="hs hs-r"></span>
      <span class="hs hs-i"></span>
    </div>
  </section>

  <!-- Three pillars -->
  <section class="section section-lg">
    <div class="container">
      <div data-reveal>
        <SectionHeader
          num="01"
          eyebrow="What we do"
          title="Three divisions, one mission."
          description="TRI AI is a branded house. Every initiative we run lives under one of three divisions that map directly to the name."
        />
      </div>
      <div data-reveal-stagger>
        <Pillars />
      </div>
    </div>
  </section>

  <hr class="divider-rule" />

  <!-- Featured programmes -->
  {programmes.length > 0 && (
    <section class="section section-lg">
      <div class="container">
        <div data-reveal>
          <SectionHeader
            num="02"
            eyebrow="Programmes"
            title="Where the work happens."
            description="Active initiatives shaping AI knowledge across the continent."
          />
        </div>
        <div class="prog-grid" data-reveal-stagger>
          {programmes.map(p => (
            <a href={`/programmes/${p.id}`} class={`prog-card prog-${p.data.division}`}>
              {p.data.cover && <div class="prog-cover" style={`background-image:url(${p.data.cover})`}></div>}
              <div class="prog-body">
                <span class={`tag tag-${p.data.division}`}>
                  triAI {p.data.division.charAt(0).toUpperCase() + p.data.division.slice(1)} programme
                </span>
                <h3 class="prog-title">{p.data.title}</h3>
                <p class="prog-tag">{p.data.tagline}</p>
                <span class="prog-link">Explore <span aria-hidden="true">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <hr class="divider-rule" />

  <!-- Recent / featured feed -->
  <section class="section section-lg">
    <div class="container">
      <div data-reveal>
        <SectionHeader
          num="03"
          eyebrow="Recent"
          title="Publications & updates."
        />
      </div>
      <div data-reveal>
        <FeaturedFeed />
      </div>
      <div class="see-all">
        <a href="/research/publications" class="btn btn-ghost btn-arrow">All publications</a>
      </div>
    </div>
  </section>

  <hr class="divider-rule" />

  <!-- Impact -->
  <section class="section section-lg impact">
    <div class="container">
      <div data-reveal>
        <SectionHeader
          num="04"
          eyebrow="Our impact"
          title="By the numbers."
          align="center"
        />
      </div>
      <div class="stats" data-reveal-stagger>
        {stats.map(s => (
          <div class="stat">
            <p class="stat-num">{s.num}</p>
            <p class="stat-label">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Newsletter />
</Base>

<style>
  /* ---------- Hero — split grid ---------- */
  .hero {
    position: relative;
    padding-block: clamp(64px, 9vw, 120px) 0;
    overflow: hidden;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: clamp(40px, 5vw, 80px);
    align-items: stretch;
    padding-bottom: clamp(56px, 7vw, 96px);
  }

  .hero-main { display: flex; flex-direction: column; }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 22px;
  }
  .hero-eyebrow .he-sep {
    margin: 0 4px;
    color: var(--gold);
    opacity: 0.7;
  }

  .hero-h {
    font-size: clamp(40px, 5.6vw, 64px);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--ink);
    max-width: 13ch;
    margin-bottom: 22px;
  }
  .hero-h-accent {
    color: var(--gold);
    font-style: italic;
    font-weight: 800;
  }

  .hero-lede {
    font-size: clamp(15.5px, 1.3vw, 18px);
    line-height: 1.6;
    color: var(--ink-mid);
    max-width: 46ch;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero-now { min-width: 0; }

  /* Division stripe — architectural footer */
  .hero-stripe {
    display: flex;
    height: 6px;
    width: 100%;
  }
  .hs { flex: 1; }
  .hs-t { background: var(--teaching); }
  .hs-r { background: var(--research); }
  .hs-i { background: var(--innovation); }
  [data-theme='dark'] .hs-r { background: var(--research-text); }

  @media (max-width: 880px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .hero-h { font-size: clamp(36px, 9vw, 52px); }
    .hero-lede { max-width: 60ch; }
  }

  /* ---------- Section size variant ---------- */
  .section-lg {
    padding-block: clamp(72px, 9vw, 128px);
  }

  /* ---------- Programmes ---------- */
  .prog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .prog-card {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-elev);
    display: flex;
    flex-direction: column;
    transition: border-color 0.25s var(--ease-quick), transform 0.25s var(--ease-quick), box-shadow 0.25s var(--ease-quick);
  }
  .prog-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px -12px rgba(20, 20, 20, 0.08);
  }
  [data-theme='dark'] .prog-card:hover {
    box-shadow: 0 8px 30px -12px rgba(0, 0, 0, 0.6);
  }
  .prog-cover {
    aspect-ratio: 16/9;
    background-size: cover;
    background-position: center;
    background-color: var(--bg-soft);
  }
  .prog-body { padding: 24px 26px 28px; }
  .prog-body .tag { margin-bottom: 14px; }
  .prog-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .prog-tag {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-mid);
    margin-bottom: 18px;
  }
  .prog-link {
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    transition: color 0.2s;
  }
  .prog-card:hover .prog-link { color: var(--gold-deep); }
  [data-theme='dark'] .prog-card:hover .prog-link { color: var(--gold); }

  .see-all {
    margin-top: 36px;
    display: flex;
    justify-content: center;
  }

  /* ---------- Impact ---------- */
  .impact { background: var(--bg-soft); }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-top: 16px;
  }
  .stat { text-align: center; }
  .stat-num {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 12px;
  }
  .stat-label {
    font-size: 13px;
    color: var(--ink-mid);
    line-height: 1.5;
    max-width: 22ch;
    margin-inline: auto;
  }

  @media (max-width: 820px) {
    .prog-grid { grid-template-columns: 1fr; }
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
