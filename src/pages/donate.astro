---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';

// ─── Payment integration ────────────────────────────────────────────
// Replace these two URLs with the Payment Links you create in Stripe
// and Paystack. Both providers let you configure a hosted payment page
// in their dashboard — no code required on our side.
//
//   Stripe:   dashboard.stripe.com → Payment Links → Create
//             Configure as "Donation", let customer pick amount,
//             enable Apple/Google Pay.
//
//   Paystack: dashboard.paystack.com → Payment Pages → Create
//             "Donations" page type, allow custom amount, enable
//             bank transfer + USSD for Nigerian donors.
//
// Both URLs accept an `?amount=` query parameter that pre-fills the
// suggested donation. The donor still has the final say on the amount
// on the payment page itself.
//
// While these are placeholder URLs the donate buttons will fall back
// to an inline message rather than navigating to a broken link.
// ────────────────────────────────────────────────────────────────────
const STRIPE_LINK = 'https://donate.stripe.com/REPLACE_ME';
const PAYSTACK_LINK = 'https://paystack.com/pay/REPLACE_ME';
const PAYMENT_CONFIGURED = !STRIPE_LINK.includes('REPLACE_ME') || !PAYSTACK_LINK.includes('REPLACE_ME');

const tiers = [
  { amount: 25, label: 'Sponsor a learner for a week' },
  { amount: 100, label: 'Equip a study group with materials' },
  { amount: 500, label: 'Fund a cohort scholarship' },
  { amount: 2500, label: 'Underwrite a research milestone' },
];
---

<Base title="Donate - TRI AI" description="Support AI education, research, and innovation across Africa.">
  <section class="hero-d">
    <div class="container hero-d-inner">
      <div>
        <p class="mono">Donate</p>
        <h1 class="display hero-d-h">
          Fund the<br/>
          <span class="hero-d-em">future of AI</span><br/>
          in Africa.
        </h1>
        <p class="lede">
          Every contribution, large or small, expands access to AI education and research for African learners and researchers. TRI AI is a registered non-governmental organisation.
        </p>
      </div>

      <aside class="donate-card">
        <p class="mono-faint">Choose an amount</p>
        <div class="tiers">
          {tiers.map(t => (
            <button type="button" class="tier" data-tier data-amount={t.amount}>
              <span class="tier-amt">${t.amount}</span>
              <span class="tier-label">{t.label}</span>
            </button>
          ))}
        </div>
        <label class="tier-custom">
          <span class="mono-faint">Custom amount (USD)</span>
          <input type="number" min="1" placeholder="Enter amount" id="custom-amt" />
        </label>

        <div class="donate-actions">
          <a
            href={STRIPE_LINK}
            class="btn btn-primary btn-arrow donate-cta"
            data-pay="stripe"
            data-base-url={STRIPE_LINK}
            target="_blank"
            rel="noopener"
          >
            Donate with card
          </a>
          <a
            href={PAYSTACK_LINK}
            class="btn btn-ghost btn-arrow donate-cta donate-cta-alt"
            data-pay="paystack"
            data-base-url={PAYSTACK_LINK}
            target="_blank"
            rel="noopener"
          >
            Pay via Naira (Paystack)
          </a>
        </div>

        <p class="donate-note">
          You'll be redirected to a secure payment page. Card donors will use Stripe (Apple Pay and Google Pay supported); Naira donors will use Paystack (cards, bank transfer, USSD). Tax-deductibility varies by jurisdiction — see receipt details after payment.
        </p>
        {!PAYMENT_CONFIGURED && (
          <p class="donate-config-warning mono">
            Payment links not yet configured. See <code>src/pages/donate.astro</code> to replace placeholders.
          </p>
        )}
      </aside>
    </div>
  </section>

  <hr class="divider-rule" />

  <section class="section">
    <div class="container">
      <h2 class="d-h2">Other ways to give.</h2>
      <div class="d-other">
        <div class="d-other-card">
          <div class="accent-bar accent-gold"></div>
          <h3>Bank transfer</h3>
          <p>For organisational gifts and recurring institutional support, contact <a href="mailto:finance@tri-ai.org">finance@tri-ai.org</a>.</p>
        </div>
        <div class="d-other-card">
          <div class="accent-bar accent-gold"></div>
          <h3>In-kind</h3>
          <p>Cloud credits, GPU access, training datasets, and venue sponsorship all extend our reach. Email <a href="mailto:partnerships@tri-ai.org">partnerships@tri-ai.org</a>.</p>
        </div>
        <div class="d-other-card">
          <div class="accent-bar accent-gold"></div>
          <h3>Time</h3>
          <p>Mentor a cohort, review research, or run a workshop. <a href="/get-involved">Get involved</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <Newsletter />
</Base>

<script is:inline>
  (function () {
    var tiers = document.querySelectorAll('[data-tier]');
    var custom = document.getElementById('custom-amt');
    var ctas = document.querySelectorAll('[data-pay]');
    var selected = null;

    function rewriteCtaUrls() {
      ctas.forEach(function (cta) {
        var base = cta.getAttribute('data-base-url');
        if (!base) return;
        if (selected && Number(selected) > 0) {
          // Stripe Payment Links and Paystack Payment Pages both
          // accept an ?amount= query param to pre-fill the donation.
          // The donor can still override on the payment page itself.
          var separator = base.indexOf('?') === -1 ? '?' : '&';
          cta.setAttribute('href', base + separator + 'amount=' + encodeURIComponent(selected));
        } else {
          cta.setAttribute('href', base);
        }
      });
    }

    tiers.forEach(function (t) {
      t.addEventListener('click', function () {
        tiers.forEach(function (x) { x.classList.remove('is-on'); });
        t.classList.add('is-on');
        selected = t.dataset.amount;
        if (custom) custom.value = '';
        rewriteCtaUrls();
      });
    });

    if (custom) {
      custom.addEventListener('input', function () {
        tiers.forEach(function (x) { x.classList.remove('is-on'); });
        selected = custom.value;
        rewriteCtaUrls();
      });
    }
  })();
</script>

<style>
  .hero-d { padding-block: clamp(64px, 8vw, 112px); }
  .hero-d-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .hero-d .mono { margin-bottom: 16px; }
  .hero-d-h {
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin-bottom: 24px;
    color: var(--ink);
  }
  .hero-d-em {
    color: var(--gold);
    font-style: italic;
  }

  .donate-card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 28px;
    position: sticky;
    top: 96px;
  }
  .donate-card .mono-faint { margin-bottom: 12px; }

  .tiers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 18px;
  }
  .tier {
    text-align: left;
    padding: 14px 14px 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s;
  }
  .tier:hover { border-color: var(--line-strong); }
  .tier.is-on {
    border-color: var(--gold);
    background: var(--gold-light);
  }
  [data-theme='dark'] .tier.is-on { background: rgba(212, 160, 23, 0.1); }
  .tier-amt {
    display: block;
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .tier-label {
    font-size: var(--t-mono);
    color: var(--ink-mid);
    line-height: 1.4;
  }

  .tier-custom { display: block; margin-bottom: 18px; }
  .tier-custom .mono-faint { margin-bottom: 8px; }
  .tier-custom input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    font-size: 14px;
  }
  .tier-custom input:focus {
    outline: none;
    border-color: var(--gold);
  }

  .donate-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 6px;
  }
  .donate-cta { width: 100%; justify-content: center; }
  .donate-note {
    font-size: var(--t-mono);
    color: var(--ink-faint);
    margin-top: 14px;
    line-height: 1.5;
  }
  .donate-config-warning {
    margin-top: 12px;
    padding: 10px 12px;
    background: rgba(217, 65, 65, 0.08);
    border-left: 3px solid #D94141;
    color: #D94141;
    font-size: var(--t-mono-sm);
    line-height: 1.5;
  }
  .donate-config-warning code {
    font-family: var(--font-mono);
    background: rgba(217, 65, 65, 0.10);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .d-h2 {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    margin-bottom: 32px;
    color: var(--ink);
  }
  .d-other {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .d-other-card {
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg-elev);
  }
  .d-other-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .d-other-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-mid);
  }
  .d-other-card a {
    color: var(--gold-deep);
    text-decoration: underline;
  }
  [data-theme='dark'] .d-other-card a { color: var(--gold); }

  @media (max-width: 920px) {
    .hero-d-inner { grid-template-columns: 1fr; }
    .donate-card { position: static; }
    .d-other { grid-template-columns: 1fr; }
  }
</style>
