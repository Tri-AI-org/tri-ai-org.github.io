---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';

// ─── Donation integration ───────────────────────────────────────────
// We use a hosted Paystack Payment Page. Donors enter card details
// on Paystack's domain, not ours — no card data ever touches our
// servers and we never hold any Paystack credentials. The integration
// is just a hyperlink with the amount appended as a query parameter,
// which the Paystack page reads and pre-fills.
//
// Reference for the query format: amount is in kobo (₦1 = 100 kobo).
// So ₦5,000 → ?amount=500000 and ₦2,000,000 → ?amount=200000000.
// The donor can still adjust the amount on Paystack's page itself.
//
// Anti-money-laundering policy: per-transaction cap below. Donations
// above the cap need a real conversation, not a one-click form. Anyone
// giving that much deserves it.
const PAYSTACK_LINK = 'https://paystack.shop/pay/triai';
const CAP_NAIRA = 2_000_000;
const PARTNERSHIPS_EMAIL = 'partnerships@tri-ai.org';

// Suggested tiers. Each rises ~5x. The largest is well below the cap
// to leave headroom for custom amounts. Labels keep the language
// invitation-rather-than-transactional.
const tiers = [
  { amount: 5_000,   label: 'Sponsor a learner for a week' },
  { amount: 20_000,  label: 'Equip a study group with materials' },
  { amount: 100_000, label: 'Fund a cohort scholarship' },
  { amount: 500_000, label: 'Underwrite a research milestone' },
];

// Human-readable currency formatter for the page.
const ngn = (n: number) => '₦' + n.toLocaleString('en-NG');
---

<Base title="Donate - TRI AI" description="Support AI education, research, and innovation across Africa.">
  <section class="hero-d">
    <div class="container hero-d-inner">
      <div>
        <p class="mono">Donate</p>
        <h1 class="display hero-d-h">
          Fund the<br/>
          <span class="hero-d-em">future of AI</span><br/>
          in Africa.
        </h1>
        <p class="lede">
          Every contribution, large or small, expands access to AI education and research for African learners and researchers. TRI AI is a registered non-governmental organisation.
        </p>
      </div>

      <aside class="donate-card">
        <p class="mono-faint">Choose an amount</p>
        <div class="tiers">
          {tiers.map(t => (
            <button type="button" class="tier" data-tier data-amount={t.amount}>
              <span class="tier-amt">{ngn(t.amount)}</span>
              <span class="tier-label">{t.label}</span>
            </button>
          ))}
        </div>
        <label class="tier-custom">
          <span class="mono-faint">Custom amount (Naira)</span>
          <input
            type="number"
            min="100"
            max={CAP_NAIRA}
            step="100"
            placeholder="e.g. 50000"
            id="custom-amt"
          />
        </label>

        <div class="donate-actions">
          <a
            href={PAYSTACK_LINK}
            class="btn btn-primary btn-arrow donate-cta"
            data-pay-cta
            data-base-url={PAYSTACK_LINK}
            target="_blank"
            rel="noopener"
          >
            Donate via Paystack
          </a>

          {/* Large-donation notice — hidden by default. The script
              reveals this when the donor enters above the cap and
              disables the Paystack button. */}
          <div class="donate-cap" data-cap-notice hidden>
            <p class="donate-cap-h">For donations above {ngn(CAP_NAIRA)}, please reach out directly.</p>
            <p class="donate-cap-body">
              We'd love to talk through how a larger gift can support a specific cohort,
              research initiative, or multi-year programme. Email
              <a href={`mailto:${PARTNERSHIPS_EMAIL}?subject=Donation%20inquiry`} class="donate-cap-mail">{PARTNERSHIPS_EMAIL}</a>
              and we'll be in touch within two working days.
            </p>
          </div>
        </div>

        <p class="donate-note">
          You'll be redirected to Paystack to complete the donation. Cards, bank transfer, and USSD are all supported. Receipt will be emailed by Paystack after payment.
        </p>
      </aside>
    </div>
  </section>

  <hr class="divider-rule" />

  <section class="section">
    <div class="container">
      <h2 class="d-h2">Other ways to give.</h2>
      <div class="d-other">
        <div class="d-other-card">
          <div class="accent-bar accent-gold"></div>
          <h3>Bank transfer</h3>
          <p>For organisational gifts and recurring institutional support, contact <a href="mailto:finance@tri-ai.org">finance@tri-ai.org</a>.</p>
        </div>
        <div class="d-other-card">
          <div class="accent-bar accent-gold"></div>
          <h3>In-kind</h3>
          <p>Cloud credits, GPU access, training datasets, and venue sponsorship all extend our reach. Email <a href="mailto:partnerships@tri-ai.org">partnerships@tri-ai.org</a>.</p>
        </div>
        <div class="d-other-card">
          <div class="accent-bar accent-gold"></div>
          <h3>Time</h3>
          <p>Mentor a cohort, review research, or run a workshop. <a href="/get-involved">Get involved</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <Newsletter />
</Base>

<script is:inline define:vars={{ CAP_NAIRA }}>
  (function () {
    var tiers = document.querySelectorAll('[data-tier]');
    var custom = document.getElementById('custom-amt');
    var cta = document.querySelector('[data-pay-cta]');
    var capNotice = document.querySelector('[data-cap-notice]');
    var selected = null;

    function setCtaState(amountNaira) {
      if (!cta) return;
      var base = cta.getAttribute('data-base-url');

      if (amountNaira && amountNaira > CAP_NAIRA) {
        // Above the cap: disable the button and reveal the email notice.
        // The button is kept visible (rather than hidden) so the donor
        // doesn't feel like the page is broken — it's clearly "you've
        // hit a limit; here's how to proceed."
        cta.classList.add('is-disabled');
        cta.setAttribute('aria-disabled', 'true');
        cta.removeAttribute('href');
        if (capNotice) capNotice.hidden = false;
        return;
      }

      // Within range. Restore href; pre-fill amount via ?amount= in kobo
      // (Paystack's smallest unit — 100 kobo per Naira).
      cta.classList.remove('is-disabled');
      cta.removeAttribute('aria-disabled');
      if (capNotice) capNotice.hidden = true;

      if (amountNaira && amountNaira > 0) {
        var kobo = Math.round(amountNaira);
        var separator = base.indexOf('?') === -1 ? '?' : '&';
        cta.setAttribute('href', base + separator + 'amount=' + kobo);
      } else {
        cta.setAttribute('href', base);
      }
    }

    tiers.forEach(function (t) {
      t.addEventListener('click', function () {
        tiers.forEach(function (x) { x.classList.remove('is-on'); });
        t.classList.add('is-on');
        selected = Number(t.dataset.amount);
        if (custom) custom.value = '';
        setCtaState(selected);
      });
    });

    if (custom) {
      custom.addEventListener('input', function () {
        tiers.forEach(function (x) { x.classList.remove('is-on'); });
        selected = Number(custom.value);
        setCtaState(selected);
      });
    }

    // Block accidental click on a disabled CTA (e.g. via keyboard/Enter).
    if (cta) {
      cta.addEventListener('click', function (e) {
        if (cta.classList.contains('is-disabled')) {
          e.preventDefault();
        }
      });
    }
  })();
</script>

<style>
  .hero-d { padding-block: clamp(64px, 8vw, 112px); }
  .hero-d-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .hero-d .mono { margin-bottom: 16px; }
  .hero-d-h {
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.02;
    margin-bottom: 24px;
    color: var(--ink);
  }
  .hero-d-em {
    color: var(--gold);
    font-style: italic;
  }

  .donate-card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 28px;
    position: sticky;
    top: 96px;
  }
  .donate-card .mono-faint { margin-bottom: 12px; }

  .tiers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 18px;
  }
  .tier {
    text-align: left;
    padding: 14px 14px 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg);
    transition: border-color 0.2s, background 0.2s;
  }
  .tier:hover { border-color: var(--line-strong); }
  .tier.is-on {
    border-color: var(--gold);
    background: var(--gold-light);
  }
  [data-theme='dark'] .tier.is-on { background: rgba(212, 160, 23, 0.1); }
  .tier-amt {
    display: block;
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .tier-label {
    font-size: var(--t-mono);
    color: var(--ink-mid);
    line-height: 1.4;
  }

  .tier-custom { display: block; margin-bottom: 18px; }
  .tier-custom .mono-faint { margin-bottom: 8px; }
  .tier-custom input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--bg);
    color: var(--ink);
    font-size: 14px;
  }
  .tier-custom input:focus {
    outline: none;
    border-color: var(--gold);
  }

  .donate-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 6px;
  }
  .donate-cta { width: 100%; justify-content: center; }

  /* Disabled state: keep the button visible but unclickable, with a
     visual cue. The cap notice below provides the alternative. */
  .donate-cta.is-disabled {
    opacity: 0.4;
    pointer-events: none;
    cursor: not-allowed;
  }

  /* Cap notice — appears under the CTA when the donor enters above
     the cap. Gold-accented so it reads as a guided handoff rather than
     an error. */
  .donate-cap {
    margin-top: 10px;
    padding: 16px 18px;
    background: var(--gold-light);
    border-left: 3px solid var(--gold);
    border-radius: 4px;
  }
  .donate-cap[hidden] { display: none; }
  .donate-cap-h {
    font-size: 14.5px;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 6px;
    line-height: 1.4;
  }
  .donate-cap-body {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-mid);
    margin: 0;
  }
  .donate-cap-mail {
    color: var(--gold-deep);
    text-decoration: underline;
    text-decoration-color: var(--gold);
    text-underline-offset: 2px;
    margin-inline: 4px;
    font-weight: 500;
  }
  [data-theme='dark'] .donate-cap-mail { color: var(--gold); }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .donate-cap-mail { color: var(--gold); }
  }

  .donate-note {
    font-size: var(--t-mono);
    color: var(--ink-faint);
    margin-top: 14px;
    line-height: 1.5;
  }

  .d-h2 {
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    margin-bottom: 32px;
    color: var(--ink);
  }
  .d-other {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .d-other-card {
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg-elev);
  }
  .d-other-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .d-other-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-mid);
  }
  .d-other-card a {
    color: var(--gold-deep);
    text-decoration: underline;
  }
  [data-theme='dark'] .d-other-card a { color: var(--gold); }

  @media (max-width: 920px) {
    .hero-d-inner { grid-template-columns: 1fr; }
    .donate-card { position: static; }
    .d-other { grid-template-columns: 1fr; }
  }
</style>
