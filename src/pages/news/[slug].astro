---
import Base from '../../layouts/Base.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news', ({ data }) => !data.draft);
  return news.map(n => ({
    params: { slug: n.id },
    props: { article: n },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const d = article.data;

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Base title={`${d.title} — TRI AI`} description={d.excerpt}>
  <article class="news">
    <div class="container news-head">
      <p class="news-bread">
        <a href="/">News</a>
        <span aria-hidden="true">·</span>
        <span class={`tag tag-${d.division === 'parent' ? 'gold' : d.division}`}>{d.division}</span>
      </p>
      <p class="news-date mono">{fmt(d.date)}</p>
      <h1 class="news-title">{d.title}</h1>
      <p class="news-excerpt">{d.excerpt}</p>
    </div>

    {d.cover && (
      <div class="container">
        <img src={d.cover} alt="" class="news-cover" />
      </div>
    )}

    <section class="section">
      <div class="container news-prose">
        <Content />
      </div>
    </section>
  </article>

  <Newsletter />
</Base>

<style is:global>
  .news-prose {
    max-width: 720px;
    margin-inline: auto;
    font-size: 17px;
    line-height: 1.8;
    color: var(--ink-mid);
  }
  .news-prose h2 {
    font-size: 26px;
    font-weight: 700;
    color: var(--ink);
    margin: 40px 0 14px;
    letter-spacing: -0.01em;
  }
  .news-prose p { margin-bottom: 20px; }
  .news-prose a { color: var(--gold-deep); text-decoration: underline; }
  [data-theme='dark'] .news-prose a { color: var(--gold); }
  .news-prose img { border-radius: 10px; margin: 28px 0; }
</style>

<style>
  .news-head {
    padding-block: clamp(48px, 6vw, 80px) 32px;
    text-align: center;
    max-width: 760px;
  }
  .news-head { margin-inline: auto; }
  .news-bread {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    justify-content: center;
  }
  .news-date {
    color: var(--ink-faint);
    margin-bottom: 16px;
  }
  .news-title {
    font-size: var(--t-display-l);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 18px;
  }
  .news-excerpt {
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.55;
    color: var(--ink-mid);
    max-width: 56ch;
    margin-inline: auto;
  }
  .news-cover {
    width: 100%;
    aspect-ratio: 16/8;
    object-fit: cover;
    border-radius: 12px;
    margin-block: 24px 0;
  }
</style>
