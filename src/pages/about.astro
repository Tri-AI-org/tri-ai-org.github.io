---
import Base from '../layouts/Base.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Newsletter from '../components/Newsletter.astro';
import EditorialSplit from '../components/EditorialSplit.astro';
import { getCollection } from 'astro:content';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
const board = team.filter(t => t.data.group === 'board');
const other_team = team.filter(t => t.data.group === 'team');
const leadership = team.filter(t => t.data.group === 'leadership');
const partners = (await getCollection('partners')).sort((a, b) => a.data.order - b.data.order);

const values = [
  { title: 'Innovation', body: 'We embrace new ideas and continuously explore ways to advance AI knowledge.' },
  { title: 'Accessibility', body: 'We believe AI education should be open and available to everyone.' },
  { title: 'Community', body: 'We grow through shared learning and collective progress.' },
  { title: 'Collaboration', body: 'We partner with organisations and individuals to amplify impact.' },
  { title: 'Empowerment', body: 'We equip individuals with the tools to build and lead.' },
];
---

<Base title="About - TRI AI" description="An institution democratising artificial intelligence in Africa through teaching, research, and innovation.">
  <!-- Eyebrow hero -->
  <section class="about-hero">
    <div class="container about-hero-grid">
      <div class="about-hero-text">
        <p class="mono">About</p>
        <h1 class="display about-h">
          An institution advancing AI in Africa.
        </h1>
        <p class="lede about-lede">
          TRI AI is a non-governmental organisation registered as Artificial Intelligence Teaching Research and Innovation for Africa Ltd/Gte. Through three divisions, the organisation advances AI education, research, and innovation across Africa.
        </p>
        <p class="mono about-since">Lagos · since 2018 · independent</p>
      </div>
      <div class="about-hero-media">
        <figure class="about-hero-fig">
          <img
            src="https://res.cloudinary.com/kenechi-dukor/image/upload/v1779277867/TRI%20AI/about1_ltfxu5.jpg"
            alt="TRI AI community in Lagos"
            loading="eager"
          />
          <figcaption class="about-hero-cap mono">The community in Lagos</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <hr class="divider-rule" />

  <!-- Editorial sections - alternating image-text -->
  <EditorialSplit
    eyebrow="Our story"
    title="From a community study group to an institution."
    body="TRI AI was founded to address the growing need for accessible and locally relevant AI education in Africa. What began as a community initiative - a Saturday study group in Lagos - has evolved into a structured institution supporting learning, research, and innovation across the continent."
    bodyExtra="Through programmes like TRI AI Saturdays Lagos and initiatives like the Sauti Project, TRI AI continues to build an ecosystem where learners, researchers, and collaborators can grow and contribute meaningfully."
    ctaLabel="Watch our story"
    ctaHref="https://www.youtube.com/watch?v=8t_lpN6KJNM"
    ctaTarget="_blank"
    imageSrc="https://res.cloudinary.com/kenechi-dukor/image/upload/v1779276964/TRI%20AI/ed69f583-7cff-4ee4-9b38-910b285a4efd_1_gz3hib.png"
    imageAlt="TRI AI community gathering in Lagos"
    imageCaption="AI Saturdays Lagos - community-led learning, since 2018"
    accent="gold"
  />

  <EditorialSplit
    eyebrow="Mission"
    title="Democratising AI in Africa."
    body="To democratise artificial intelligence by building African AI communities that enable learning, research, and the development of AI solutions for local and global impact."
    bodyExtra="Every programme we run, every paper we publish, and every dataset we release is part of this mission - making the field accessible to people who would otherwise be locked out, and ensuring African contexts are represented in the technologies that shape the future."
    imageSrc="https://res.cloudinary.com/kenechi-dukor/image/upload/v1779355606/TRI%20AI/about3_ni84zx.jpg"
    imageAlt="Researchers collaborating on a project"
    imageCaption="Open research, openly distributed"
    imageRight={true}
    accent="gold"
  />

  <EditorialSplit
    eyebrow="Vision"
    title="Be at the forefront of AI"
    body="To be at the forefront of building self-sustaining, research-driven, and globally recognised Artificial Intelligence innovation in Africa."
    imageSrc="https://res.cloudinary.com/kenechi-dukor/image/upload/v1779331470/TRI%20AI/about_scggqn.jpg"
    imageAlt="Speaker presenting research at a conference"
    imageCaption="Research presented at NeurIPS, the Deep Learning Indaba, and beyond"
    accent="gold"
  />

  <hr class="divider-rule" />

  <!-- Values -->
  <section class="section">
    <div class="container">
      <div data-reveal>
        <SectionHeader num="02" eyebrow="What we stand for" title="Our values." />
      </div>
      <div class="values" data-reveal-stagger>
        {values.map((v, i) => (
          <div class="value-cell">
            <p class="value-num mono">0{i + 1}</p>
            <h3 class="value-h">{v.title}</h3>
            <p class="value-body">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="divider-rule" />

  <!-- Watch our story - YouTube embed -->
  <section class="section video-sec">
    <div class="container">
      <div data-reveal>
        <p class="mono video-eyebrow">A short film</p>
        <h2 class="video-title">Building learning communities for AI in Nigeria.</h2>
        <p class="video-lede">
          A short documentary from 2021, made with Dr. Opeyemi Emoruwa, telling the story of how AI Saturdays Lagos came to be.
        </p>
      </div>
      <div class="video-frame" data-reveal>
        <iframe
          src="https://www.youtube-nocookie.com/embed/8t_lpN6KJNM"
          title="Our Story - Building Learning Communities for AI in Nigeria"
          frameborder="0"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <hr class="divider-rule" />

  <!-- Team -->
  <section class="section" id="team">
    <div class="container">
      <div data-reveal>
        <SectionHeader
          num="03"
          eyebrow="Leadership"
          title="A growing network."
          description="Educators, researchers, and volunteers committed to democratising AI across Africa."
        />
      </div>

      {board.length > 0 && (
        <>
          <p class="mono team-group-label">Board of trustees</p>
          <div class="team-grid" data-reveal-stagger>
            {board.map(t => (
              <div class="team-card">
                {t.data.photo && <img src={t.data.photo} alt={t.data.name} class="team-photo" loading="lazy" />}
                <h3 class="team-name">{t.data.name}</h3>
                <p class="team-role">{t.data.role}</p>
                {t.data.linkedin && <a href={t.data.linkedin} class="team-link">LinkedIn →</a>}
              </div>
            ))}
          </div>
        </>
      )}

      {leadership.length > 0 && (
        <>
          <p class="mono team-group-label" style="margin-top: 64px">Leadership team</p>
          <div class="team-grid" data-reveal-stagger>
            {leadership.map(t => (
              <div class="team-card">
                {t.data.photo && <img src={t.data.photo} alt={t.data.name} class="team-photo" loading="lazy" />}
                <h3 class="team-name">{t.data.name}</h3>
                <p class="team-role">{t.data.role}</p>
                {t.data.linkedin && <a href={t.data.linkedin} class="team-link">LinkedIn →</a>}
              </div>
            ))}
          </div>
        </>
      )}

      {other_team.length > 0 && (
        <>
          <p class="mono team-group-label" style="margin-top: 64px">Team</p>
          <div class="team-grid" data-reveal-stagger>
            {other_team.map(t => (
              <div class="team-card">
                {t.data.photo && <img src={t.data.photo} alt={t.data.name} class="team-photo" loading="lazy" />}
                <h3 class="team-name">{t.data.name}</h3>
                <p class="team-role">{t.data.role}</p>
                {t.data.linkedin && <a href={t.data.linkedin} class="team-link">LinkedIn →</a>}
              </div>
            ))}
          </div>
        </>
      )}

      {team.length === 0 && (
        <p class="empty">Team members will be listed here. Add them via the CMS.</p>
      )}
    </div>
  </section>

  {partners.length > 0 && (
    <>
      <hr class="divider-rule" />
      <section class="section partners-sec" id="partners">
        <div class="container">
          <div data-reveal>
            <SectionHeader num="04" eyebrow="Partners & supporters" title="We don't do this alone." align="center" />
          </div>
          <div class="partner-row" data-reveal-stagger>
            {partners.map(p => (
              <a href={p.data.url || '#'} class="partner-logo">
                <img src={p.data.logo} alt={p.data.name} loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </section>
    </>
  )}

  <Newsletter />
</Base>

<style>
  .about-hero {
    padding-block: clamp(56px, 7vw, 96px);
  }
  .about-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }
  .about-hero-text { display: flex; flex-direction: column; }
  .about-hero .mono { margin-bottom: 16px; }
  .about-h {
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 24px;
    color: var(--ink);
    max-width: 16ch;
  }
  .about-lede {
    color: var(--ink-mid);
    max-width: 52ch;
    margin-bottom: 28px;
  }
  .about-since {
    font-size: var(--t-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding-top: 18px;
    border-top: 1px solid var(--line);
    align-self: flex-start;
  }

  .about-hero-fig {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-soft);
  }
  .about-hero-fig img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
  }
  .about-hero-cap {
    padding: 12px 18px 14px;
    font-size: var(--t-mono-sm);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    border-top: 1px solid var(--line);
    background: var(--bg-elev);
  }

  @media (max-width: 880px) {
    .about-hero-grid { grid-template-columns: 1fr; gap: 32px; }
    .about-h { max-width: none; }
  }

  /* Video section */
  .video-sec { background: var(--bg-soft); }
  .video-eyebrow {
    color: var(--gold-deep);
    font-size: var(--t-mono);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  [data-theme='dark'] .video-eyebrow { color: var(--gold); }
  .video-title {
    font-size: clamp(26px, 3.4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 16px;
    max-width: 22ch;
  }
  .video-lede {
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.6;
    color: var(--ink-mid);
    max-width: 56ch;
    margin-bottom: 36px;
  }
  .video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
  }
  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }
  .about-cell h2 {
    font-size: var(--t-h2);
    margin-bottom: 16px;
    color: var(--ink);
  }
  .about-cell p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-mid);
    margin-bottom: 14px;
  }
  .ms-quote {
    font-size: 17px !important;
    font-style: italic;
    color: var(--ink) !important;
    line-height: 1.55 !important;
    border-left: 3px solid var(--gold);
    padding-left: 16px;
  }

  .values {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .value-cell {
    padding: 28px 24px 32px;
    border-right: 1px solid var(--line);
  }
  .value-cell:last-child { border-right: 0; }
  .value-num { color: var(--gold-deep); margin-bottom: 18px; }
  [data-theme='dark'] .value-num { color: var(--gold); }
  .value-h {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .value-body {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--ink-mid);
  }

  .team-group-label {
    margin-bottom: 24px;
    color: var(--ink-faint);
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px 24px;
  }
  .team-card { text-align: left; }
  .team-photo {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 14px;
    background: var(--bg-soft);
  }
  .team-name {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 4px;
    color: var(--ink);
  }
  .team-role {
    font-size: 13px;
    color: var(--ink-mid);
    line-height: 1.5;
    margin-bottom: 6px;
  }
  .team-link {
    font-size: var(--t-mono);
    font-family: var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  [data-theme='dark'] .team-link { color: var(--gold); }

  .partners-sec { background: var(--bg-soft); }

  /* Uniform grid cells: each partner gets a same-sized box, logo centered
     inside with generous padding. This is what makes a logo wall look
     coherent even though every brand provides their logo in a different
     aspect ratio and file format. */
  .partner-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 8px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .partner-logo {
    /* Each cell: fixed height, centered content, comfortable inner padding.
       The padding is what lets logos with built-in whitespace (Arewa, CMU
       JPGs) read at roughly the same scale as wordmark SVGs. */
    display: flex;
    align-items: center;
    justify-content: center;
    height: 110px;
    padding: 18px 22px;
    border-radius: 4px;
    transition: background 0.2s var(--ease-quick);
  }
  .partner-logo:hover {
    background: var(--bg);
  }
  .partner-logo img {
    /* Cap both dimensions so wide and tall logos both stay inside the cell.
       object-fit ensures aspect ratio is preserved regardless of source. */
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;

    /* Grayscale + reduced opacity normalizes brands across the wall.
       Google's blue, Cohere's coral, Cisco's blue all compete for
       attention in full color; rendered as monotone they read as
       typography with equal weight. On hover, restore full color. */
    filter: grayscale(100%);
    opacity: 0.55;
    transition: filter 0.25s var(--ease-quick), opacity 0.25s var(--ease-quick);
  }
  .partner-logo:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* Dark mode: dark logos disappear against dark background. Invert them
     so light marks float on dark, restored to brand color on hover. */
  [data-theme='dark'] .partner-logo img {
    filter: grayscale(100%) brightness(0) invert(1);
    opacity: 0.5;
  }
  [data-theme='dark'] .partner-logo:hover img {
    filter: grayscale(0%) brightness(1) invert(0);
    opacity: 1;
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .partner-logo img {
      filter: grayscale(100%) brightness(0) invert(1);
      opacity: 0.5;
    }
    :root:not([data-theme]) .partner-logo:hover img {
      filter: grayscale(0%) brightness(1) invert(0);
      opacity: 1;
    }
  }

  @media (max-width: 720px) {
    .partner-row {
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    }
    .partner-logo {
      height: 90px;
      padding: 14px 16px;
    }
  }

  .empty {
    padding: 32px;
    text-align: center;
    color: var(--ink-faint);
    border: 1px dashed var(--line);
    border-radius: 10px;
  }

  @media (max-width: 920px) {
    .about-grid { grid-template-columns: 1fr; gap: 48px; }
    .values { grid-template-columns: repeat(2, 1fr); }
    .value-cell { border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .values { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: 1fr 1fr; gap: 20px 14px; }
  }
</style>
