---
import Base from '../../layouts/Base.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const researchProgs = (await getCollection('programmes'))
  .filter(p => p.data.division === 'research')
  .sort((a, b) => a.data.order - b.data.order);

const recentPubs = (await getCollection('publications', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<Base title="Research — TRI AI">
  <section class="hero-r">
    <div class="container">
      <div class="accent-bar accent-research"></div>
      <p class="mono">Research</p>
      <h1 class="display hero-r-h">
        African questions,
        <span class="hero-r-em">global answers.</span>
      </h1>
      <p class="lede">
        TRI AI Research drives initiatives that address African challenges while contributing to the global AI ecosystem — building datasets, tools, and methods that move the field forward.
      </p>

      {researchProgs.length > 0 && (
        <p class="hero-r-current mono">
          <span class="hero-r-current-label">Currently studying</span>
          {researchProgs.map((p, i) => (
            <>
              <a href={`/programmes/${p.id}`} class="hero-r-current-item">{p.data.title}</a>
              {i < researchProgs.length - 1 && <span class="hero-r-current-sep" aria-hidden="true">·</span>}
            </>
          ))}
        </p>
      )}
    </div>
  </section>

  <hr class="divider-rule" />

  {researchProgs.length > 0 && (
    <section class="section">
      <div class="container">
        <div data-reveal>
          <SectionHeader num="01" eyebrow="Initiatives" title="What we're working on." />
        </div>
        <div class="r-list" data-reveal-stagger>
          {researchProgs.map(p => (
            <a href={`/programmes/${p.id}`} class="r-card">
              {p.data.cover && (
                <div class="r-card-cover">
                  <img src={p.data.cover} alt="" loading="lazy" />
                </div>
              )}
              <div class="r-card-body">
                <h2 class="r-card-title">{p.data.title}</h2>
                <p class="r-card-tag">{p.data.tagline}</p>
                <span class="r-card-link">Read more →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {recentPubs.length > 0 && (
    <>
      <hr class="divider-rule" />
      <section class="section">
        <div class="container">
          <div data-reveal>
            <SectionHeader num="02" eyebrow="Publications" title="Recent papers." />
          </div>
          <ul class="rp-list" data-reveal-stagger>
            {recentPubs.map(p => (
              <li>
                <a href={`/research/publications/${p.id}`} class="rp-link">
                  <span class="rp-date mono">{fmt(p.data.date)}</span>
                  <span class="rp-title">{p.data.title}</span>
                  <span class="rp-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
          <div style="margin-top: 32px">
            <a href="/research/publications" class="btn btn-ghost btn-arrow">All publications</a>
          </div>
        </div>
      </section>
    </>
  )}

  <Newsletter />
</Base>

<style>
  .hero-r { padding-block: clamp(64px, 8vw, 112px); }
  .hero-r .accent-bar { margin-bottom: 16px; }
  .hero-r .mono { margin-bottom: 16px; color: var(--research-text); }
  .hero-r-h {
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 24px;
    color: var(--ink);
  }
  .hero-r-em {
    display: inline-block;
    color: var(--research);
    font-style: italic;
    font-weight: 600;
    font-size: 0.78em;
    line-height: 1.15;
    margin-top: 4px;
  }
  [data-theme='dark'] .hero-r-em { color: var(--research-text); }

  .hero-r-current {
    margin-top: 28px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 14px;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .hero-r-current-label {
    color: var(--ink-faint);
    margin-right: 6px;
  }
  .hero-r-current-item {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .hero-r-current-item:hover {
    color: var(--research-text);
    border-bottom-color: var(--research-text);
  }
  .hero-r-current-sep { color: var(--ink-faint); opacity: 0.5; }

  .r-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .r-card {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-left: 3px solid var(--research);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.25s var(--ease-quick), transform 0.25s var(--ease-quick), box-shadow 0.25s var(--ease-quick);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .r-card:hover {
    border-color: var(--line-strong);
    border-left-color: var(--research);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px -12px rgba(20, 20, 20, 0.08);
  }
  [data-theme='dark'] .r-card:hover {
    box-shadow: 0 8px 30px -12px rgba(0, 0, 0, 0.6);
  }
  .r-card-cover {
    overflow: hidden;
    aspect-ratio: 16/9;
    background: var(--bg-soft);
  }
  .r-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s var(--ease);
  }
  .r-card:hover .r-card-cover img { transform: scale(1.04); }
  .r-card-body { padding: 24px 28px 26px; }
  .r-card-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--ink);
  }
  .r-card-tag {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-mid);
    margin-bottom: 18px;
  }
  .r-card-link {
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .rp-list { list-style: none; border-top: 1px solid var(--line); }
  .rp-link {
    display: grid;
    grid-template-columns: 110px 1fr 24px;
    gap: 20px;
    align-items: center;
    padding: 22px 8px;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.2s var(--ease-quick);
  }
  .rp-link:hover { padding-left: 16px; background: var(--bg-soft); }
  .rp-date { color: var(--ink-faint); font-size: 10px; }
  .rp-title { font-size: 16px; font-weight: 500; color: var(--ink); line-height: 1.4; }
  .rp-arrow { color: var(--ink-faint); font-size: 18px; transition: transform 0.2s; }
  .rp-link:hover .rp-arrow { transform: translateX(4px); color: var(--gold-deep); }

  @media (max-width: 820px) {
    .r-list { grid-template-columns: 1fr; }
    .rp-link {
      grid-template-columns: 1fr 24px;
    }
    .rp-date { grid-column: 1 / -1; margin-bottom: -8px; }
  }
</style>
